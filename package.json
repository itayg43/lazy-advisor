{
  "name": "lazy-advisor",
  "version": "1.0.0",
  "description": "Agentic investment planning CLI for beginner ETF investors",
  "scripts": {
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:server": "tsx watch src/server/server.ts",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/itayg43/lazy-advisor.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "imports": {
    "#shared/*": "./src/shared/*",
    "#server/*": "./src/server/*"
  },
  "bugs": {
    "url": "https://github.com/itayg43/lazy-advisor/issues"
  },
  "homepage": "https://github.com/itayg43/lazy-advisor#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "prettier": "^3.8.1",
    "prisma": "^7.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "dotenv": "^17.3.1",
    "envalid": "^8.1.1",
    "http-status-codes": "^2.3.0"
  }
}
